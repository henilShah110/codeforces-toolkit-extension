{
  "manifest_version": 3,
  "name": "Codeforces Contest Opener",
  "version": "1.0",

  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "tabGroups"
  ],

  "host_permissions": [
    "https://codeforces.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["https://codeforces.com/*"],
      "js": ["content.js"]
    }
  ],

  "commands": {
    "open-all-problems": {
      "suggested_key": {
        "default": "Ctrl+Shift+O"
      },
      "description": "Open all contest problems"
    }
  }
}